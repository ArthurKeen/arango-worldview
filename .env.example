## ArangoDB (Docker)
# Pick a port NOT used by your other Arango containers.
# This repo defaults to 48529 because this machine already uses 28529 and 38529.
ARANGO_HOST_PORT=48529

# Required (choose your own password)
ARANGO_ROOT_PASSWORD=change-me

# Optional (planned default DB name)
ARANGO_DB_NAME=worldview

## App services (local)
# Backend API (Fastify)
API_PORT=8080

# Shared Arango client settings (used by API + ingest)
ARANGO_URL=http://localhost:${ARANGO_HOST_PORT}
ARANGO_USERNAME=root
ARANGO_PASSWORD=${ARANGO_ROOT_PASSWORD}

# Ingestion
INGEST_TICK_MS=15000
# Optional bbox to reduce OpenSky payload: "west,south,east,north"
# OPENSKY_BBOX=-125,25,-66,50

