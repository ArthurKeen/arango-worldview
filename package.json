{
  "name": "arango-worldview",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,ingest,web -c blue,magenta,green \"npm:dev -w services/api\" \"npm:dev -w services/ingest\" \"npm:dev -w apps/web\"",
    "dev:api": "npm run dev -w services/api",
    "dev:ingest": "npm run dev -w services/ingest",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -ws",
    "lint": "npm run lint -ws"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "keywords": [
    "arangodb",
    "cesium",
    "resium",
    "nextjs",
    "fastify",
    "opensky",
    "celestrak",
    "3d-globe",
    "geospatial",
    "real-time"
  ],
  "author": "Arthur Keen <aakeen@yahoo.com>",
  "license": "ISC",
  "description": "Browser-based 3D globe command center fusing real-time OpenSky aircraft, CelesTrak satellites, and events into an interactive 4D map powered by ArangoDB.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArthurKeen/arango-worldview.git"
  },
  "bugs": {
    "url": "https://github.com/ArthurKeen/arango-worldview/issues"
  },
  "homepage": "https://github.com/ArthurKeen/arango-worldview#readme"
}
